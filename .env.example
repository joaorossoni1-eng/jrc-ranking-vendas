# Porta do servidor
PORT=3000

# Ambiente: development | production
NODE_ENV=development

# Caminho do arquivo SQLite (usado quando DB_CLIENT=sqlite)
DB_CLIENT=sqlite
SQLITE_PATH=./database/jrc_ranking.db

# --- Configuração alternativa para PostgreSQL (opcional) ---
# Para migrar para PostgreSQL, defina DB_CLIENT=postgres e preencha os campos abaixo.
# Veja o README.md, seção "Migrando para PostgreSQL".
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=jrc_ranking
PG_USER=postgres
PG_PASSWORD=postgres

# Segredo usado para assinar o token de sessão do admin
SESSION_SECRET=jrc-troque-este-segredo-em-producao
